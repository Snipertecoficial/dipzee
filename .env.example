# Copy this file to `.env` in the repo root and fill in real values before
# running `docker compose up --build`. Never commit the real `.env`.

# ---- Runtime -----------------------------------------------------------
ENV=production
DOMAIN=seudominio.com

# ---- MongoDB -------------------------------------------------------------
# MONGO_URL is derived automatically in docker-compose.yml. Root credentials
# are used ONLY for cluster administration (see mongo-init/init-app-user.js);
# the backend connects with MONGO_APP_USER, which is scoped to readWrite on
# DB_NAME only — never the root/admin account.
MONGO_ROOT_USER=dipzee_admin
MONGO_ROOT_PASSWORD=changeme-strong-password
MONGO_APP_USER=dipzee_app
MONGO_APP_PASSWORD=changeme-different-strong-password
DB_NAME=dipzee_production

# ---- Auth ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Short-lived access token; long-lived but revocable refresh token (see
# backend/refresh_tokens.py) is what actually keeps a session alive.
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=https://seudominio.com

# Superadmin account(s), created/updated on every backend startup. No
# built-in fallback exists anymore — if unset, no superadmin is seeded.
SUPERADMIN_EMAIL=voce@seudominio.com
SUPERADMIN_PASSWORD=

# ---- Stripe (live keys) ------------------------------------------------
STRIPE_API_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# From the Stripe webhook endpoint pointed at https://seudominio.com/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Email (Resend) ----------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Dipzee <noreply@seudominio.com>

# ---- AI analyst (Anthropic or Gemini) ----------------------------------
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GOOGLE_API_KEY=
GEMINI_MODEL=

# ---- Optional: Telegram alerts -----------------------------------------
TELEGRAM_BOT_TOKEN=

# ---- Optional: market data providers (yfinance is the built-in default,
# not licensed for commercial use — set one of these before charging users) --
FINNHUB_API_KEY=
FMP_API_KEY=
POLYGON_API_KEY=
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
MARKETSTACK_API_KEY=

# ---- Frontend (baked into the JS bundle at build time) -----------------
REACT_APP_BACKEND_URL=https://seudominio.com
